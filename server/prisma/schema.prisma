generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  engineer
  tm
  admin
}

enum Season {
  summer
  winter
}

enum VisitStatus {
  planned
  not_started
  in_progress
  completed
  sent
  sent_by_engineer
  sent_by_tm
  corrected_by_tm
}

enum TaskStatus {
  not_started
  in_progress
  completed
}

enum Conclusion {
  ok
  ok_with_notes
  faulty
}

enum PhotoMoment {
  before
  after
}

model User {
  id                 String   @id @default(uuid())
  fullName           String   @map("full_name")
  email              String   @unique
  passwordHash       String   @map("password_hash")
  role               UserRole @default(engineer)
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  specializationVik  Boolean  @default(false) @map("specialization_vik")
  specializationIszh Boolean  @default(true)  @map("specialization_iszh")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  visits         Visit[]              @relation("UserVisits")
  assignedVisits Visit[]              @relation("AssignedVisits")
  auditLogs      AuditLog[]
  resetTokens    PasswordResetToken[]
  tmObjects      TmObject[]           @relation("TmObjectRelation")
  tmEngineers    TmEngineer[]         @relation("TmEngineerTmRelation")
  engineersAsTm  TmEngineer[]         @relation("TmEngineerEngineerRelation")
  deletedVisits            Visit[]              @relation("DeletedBy")
  equipmentProposals       EquipmentProposal[]  @relation("proposedBy")
  reviewedProposals        EquipmentProposal[]  @relation("reviewedBy")
  favoriteObjects          UserFavoriteObject[]
  confirmedObjectEquipment ObjectEquipment[]    @relation("objectEquipmentRoomConfirm")
  reportAttachments        ReportAttachment[]   @relation("ReportAttachmentUploader")
  reportTasks              ReportTask[]         @relation("ReportTaskCreator")

  @@map("users")
}

model Address {
  id            String   @id @default(uuid())
  city          String
  street        String
  house         String
  building      String?
  fullAddress   String   @map("full_address")
  customerEmail String?  @map("customer_email")
  objectCode    String?  @unique @map("object_code")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  visits              Visit[]
  tmObjects           TmObject[]
  objectEquipment     ObjectEquipment[]
  equipmentProposals  EquipmentProposal[]
  favoriteObjects     UserFavoriteObject[]

  @@index([city, street])
  @@map("addresses")
}

model EquipmentType {
  id                String  @id @default(uuid())
  name              String
  code              String  @unique
  photosRequired    Int     @default(1) @map("photos_required")
  isActive          Boolean @default(true) @map("is_active")
  specializationReq String? @map("specialization_req")

  tasks           Task[]
  recommendations Recommendation[]

  @@map("equipment_types")
}

model RoomType {
  id   String @id @default(uuid())
  name String
  code String @unique

  tasks Task[]

  @@map("room_types")
}

model Recommendation {
  id              String  @id @default(uuid())
  equipmentTypeId String  @map("equipment_type_id")
  text            String
  sortOrder       Int     @default(0) @map("sort_order")
  isActive        Boolean @default(true) @map("is_active")

  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])

  @@index([equipmentTypeId, sortOrder])
  @@map("recommendations")
}

model Visit {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  addressId        String      @map("address_id")
  engineerName     String      @map("engineer_name")
  dateStart        DateTime    @map("date_start")
  timeStart        String      @map("time_start")
  timeEnd          String?     @map("time_end")
  season           Season
  status           VisitStatus @default(in_progress)
  assignedById     String?     @map("assigned_by_id")
  assignedAt       DateTime?   @map("assigned_at")
  sentByEngineerAt DateTime?   @map("sent_by_engineer_at")
  sentByTmAt       DateTime?   @map("sent_by_tm_at")
  tmCorrected      Boolean     @default(false) @map("tm_corrected")
  isDeleted        Boolean     @default(false) @map("is_deleted")
  deletedById      String?     @map("deleted_by_id")
  deletedAt        DateTime?   @map("deleted_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user       User    @relation("UserVisits", fields: [userId], references: [id])
  assignedBy User?   @relation("AssignedVisits", fields: [assignedById], references: [id])
  deletedBy  User?   @relation("DeletedBy", fields: [deletedById], references: [id])
  address    Address @relation(fields: [addressId], references: [id])
  tasks      Task[]

  @@index([userId, dateStart])
  @@index([status])
  @@index([assignedById])
  @@index([isDeleted])
  @@map("visits")
}

model Task {
  id                        String      @id @default(uuid())
  visitId                   String      @map("visit_id")
  taskType                  String      @default("individual") @map("task_type")
  equipmentTypeId           String      @map("equipment_type_id")
  roomTypeId                String?     @map("room_type_id")
  roomTypeCode              String?     @map("room_type_code")
  objectEquipmentId         String?     @map("object_equipment_id")
  comment                   String?
  brand                     String?
  model                     String?
  serialNumber              String?     @map("serial_number")
  sortOrder                 Int         @default(0) @map("sort_order")
  status                    TaskStatus  @default(not_started)
  parameters                Json?
  selectedRecommendationIds String[]    @default([]) @map("selected_recommendation_ids")
  additionalRecommendations String?     @map("additional_recommendations")
  conclusion                Conclusion?
  createdAt                 DateTime    @default(now()) @map("created_at")
  updatedAt                 DateTime    @updatedAt @map("updated_at")

  visit            Visit               @relation(fields: [visitId], references: [id], onDelete: Cascade)
  equipmentType    EquipmentType       @relation(fields: [equipmentTypeId], references: [id])
  roomType         RoomType?           @relation(fields: [roomTypeId], references: [id])
  objectEquipment  ObjectEquipment?    @relation(fields: [objectEquipmentId], references: [id])
  photos           Photo[]
  equipmentItems   TaskEquipmentItem[]

  @@index([visitId, status])
  @@map("tasks")
}

model Photo {
  id                  String      @id @default(uuid())
  taskId              String?     @map("task_id")
  taskEquipmentItemId String?     @map("task_equipment_item_id")
  fileName            String      @map("file_name")
  filePath            String      @map("file_path")
  moment              PhotoMoment
  fileSize            Int?        @map("file_size")
  mimeType            String?     @map("mime_type")
  createdAt           DateTime    @default(now()) @map("created_at")

  task              Task?              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskEquipmentItem TaskEquipmentItem? @relation(fields: [taskEquipmentItemId], references: [id], onDelete: Cascade)

  @@unique([taskId, moment])
  @@unique([taskEquipmentItemId, moment])
  @@index([taskId, moment])
  @@index([taskEquipmentItemId, moment])
  @@map("photos")
}

model TaskEquipmentItem {
  id                String   @id @default(uuid())
  taskId            String   @map("task_id")
  objectEquipmentId String   @map("object_equipment_id")
  status            String?
  sortOrder         Int      @default(0) @map("sort_order")
  createdAt         DateTime @default(now()) @map("created_at")

  task            Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  objectEquipment ObjectEquipment   @relation(fields: [objectEquipmentId], references: [id])
  photos          Photo[]

  @@unique([taskId, objectEquipmentId])
  @@index([taskId])
  @@map("task_equipment_items")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_log")
}

model TmObject {
  id        String   @id @default(uuid())
  tmId      String   @map("tm_id")
  addressId String   @map("address_id")
  createdAt DateTime @default(now()) @map("created_at")

  tm      User    @relation("TmObjectRelation", fields: [tmId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([tmId, addressId])
  @@index([tmId])
  @@index([addressId])
  @@map("tm_objects")
}

model TmEngineer {
  id         String   @id @default(uuid())
  tmId       String   @map("tm_id")
  engineerId String   @map("engineer_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tm       User @relation("TmEngineerTmRelation", fields: [tmId], references: [id], onDelete: Cascade)
  engineer User @relation("TmEngineerEngineerRelation", fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([engineerId])
  @@index([tmId])
  @@index([engineerId])
  @@map("tm_engineers")
}

model ImportLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  entityType    String   @map("entity_type")
  fileName      String   @map("file_name")
  totalRows     Int      @map("total_rows")
  successRows   Int      @map("success_rows")
  duplicateRows Int      @default(0) @map("duplicate_rows")
  errorRows     Int      @map("error_rows")
  errors        Json?
  status        String   @default("completed")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entityType])
  @@map("import_logs")
}

model ObjectEquipment {
  id                  String    @id @default(uuid())
  addressId           String    @map("address_id")
  equipmentTypeCode   String    @map("equipment_type_code")
  roomTypeCode        String?   @map("room_type_code")
  brand               String?
  model               String?
  serialNumber        String?   @map("serial_number")
  locationDescription String?   @map("location_description")
  isOutdoorUnit       Boolean   @default(false) @map("is_outdoor_unit")
  isActive            Boolean   @default(true) @map("is_active")
  roomConfirmedAt     DateTime? @map("room_confirmed_at")
  roomConfirmedBy     String?   @map("room_confirmed_by")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  address             Address             @relation(fields: [addressId], references: [id], onDelete: Cascade)
  roomConfirmedByUser User?               @relation("objectEquipmentRoomConfirm", fields: [roomConfirmedBy], references: [id])
  tasks               Task[]
  taskEquipmentItems  TaskEquipmentItem[]

  @@unique([addressId, equipmentTypeCode, serialNumber])
  @@unique([addressId, equipmentTypeCode, locationDescription])
  @@index([addressId])
  @@index([equipmentTypeCode])
  @@map("object_equipment")
}

model EquipmentProposal {
  id                  String    @id @default(uuid())
  addressId           String    @map("address_id")
  address             Address   @relation(fields: [addressId], references: [id])
  equipmentTypeCode   String    @map("equipment_type_code")
  roomTypeCode        String    @map("room_type_code")
  brand               String?
  model               String?
  serialNumber        String?   @map("serial_number")
  locationDescription String?   @map("location_description")
  proposedById        String    @map("proposed_by_id")
  proposedBy          User      @relation("proposedBy", fields: [proposedById], references: [id])
  status              String    @default("pending")
  reviewedById        String?   @map("reviewed_by_id")
  reviewedBy          User?     @relation("reviewedBy", fields: [reviewedById], references: [id])
  reviewedAt          DateTime? @map("reviewed_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([addressId])
  @@index([status])
  @@map("equipment_proposals")
}

model UserFavoriteObject {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  objectCode String   @map("object_code")
  addedAt    DateTime @default(now()) @map("added_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [objectCode], references: [objectCode], onDelete: Cascade)

  @@unique([userId, objectCode])
  @@index([userId])
  @@map("user_favorite_objects")
}

model ReportAttachment {
  id           String   @id @default(uuid())
  reportTaskId String?  @map("report_task_id")
  filePath     String   @map("file_path")
  fileType     String   @map("file_type")
  originalName String?  @map("original_name")
  fileSize     Int?     @map("file_size")
  uploadedBy   String   @map("uploaded_by")
  createdAt    DateTime @default(now()) @map("created_at")

  reportTask ReportTask? @relation(fields: [reportTaskId], references: [id], onDelete: SetNull)
  uploader   User        @relation("ReportAttachmentUploader", fields: [uploadedBy], references: [id])

  @@index([reportTaskId])
  @@map("report_attachments")
}

model ReportTask {
  id            String    @id @default(uuid())
  type          String
  params        Json
  status        String    @default("processing")
  pdfPath       String?   @map("pdf_path")
  photosZipPath String?   @map("photos_zip_path")
  errorMessage  String?   @map("error_message")
  createdBy     String    @map("created_by")
  createdAt     DateTime  @default(now()) @map("created_at")
  completedAt   DateTime? @map("completed_at")

  creator     User               @relation("ReportTaskCreator", fields: [createdBy], references: [id])
  attachments ReportAttachment[]

  @@map("report_tasks")
}
