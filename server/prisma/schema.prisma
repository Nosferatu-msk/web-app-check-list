generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  engineer
  admin
}

enum Season {
  summer
  winter
}

enum VisitStatus {
  in_progress
  completed
  sent
}

enum TaskStatus {
  not_started
  in_progress
  completed
}

enum Conclusion {
  ok
  ok_with_notes
  faulty
}

enum PhotoMoment {
  before
  after
}

model User {
  id            String   @id @default(uuid())
  fullName      String   @map("full_name")
  email         String   @unique
  passwordHash  String   @map("password_hash")
  role          UserRole @default(engineer)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  visits      Visit[]
  auditLogs   AuditLog[]
  resetTokens PasswordResetToken[]

  @@map("users")
}

model Address {
  id            String   @id @default(uuid())
  city          String
  street        String
  house         String
  building      String?
  fullAddress   String   @map("full_address")
  customerEmail String?  @map("customer_email")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  visits Visit[]

  @@index([city, street])
  @@map("addresses")
}

model EquipmentType {
  id             String  @id @default(uuid())
  name           String
  code           String  @unique
  photosRequired Int     @default(1) @map("photos_required")
  isActive       Boolean @default(true) @map("is_active")

  tasks           Task[]
  recommendations Recommendation[]

  @@map("equipment_types")
}

model RoomType {
  id   String @id @default(uuid())
  name String
  code String @unique

  tasks Task[]

  @@map("room_types")
}

model Recommendation {
  id              String  @id @default(uuid())
  equipmentTypeId String  @map("equipment_type_id")
  text            String
  sortOrder       Int     @default(0) @map("sort_order")
  isActive        Boolean @default(true) @map("is_active")

  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])

  @@index([equipmentTypeId, sortOrder])
  @@map("recommendations")
}

model Visit {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  addressId     String      @map("address_id")
  engineerName  String      @map("engineer_name")
  dateStart     DateTime    @map("date_start")
  timeStart     String      @map("time_start")
  timeEnd       String?     @map("time_end")
  season        Season
  status        VisitStatus @default(in_progress)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id])
  address Address @relation(fields: [addressId], references: [id])
  tasks   Task[]

  @@index([userId, dateStart])
  @@index([status])
  @@map("visits")
}

model Task {
  id                        String     @id @default(uuid())
  visitId                   String     @map("visit_id")
  equipmentTypeId           String     @map("equipment_type_id")
  roomTypeId                String?    @map("room_type_id")
  location                  String?
  sortOrder                 Int        @default(0) @map("sort_order")
  status                    TaskStatus @default(not_started)
  parameters                Json?
  selectedRecommendationIds String[]   @default([]) @map("selected_recommendation_ids")
  additionalRecommendations String?    @map("additional_recommendations")
  conclusion                Conclusion?
  createdAt                 DateTime   @default(now()) @map("created_at")
  updatedAt                 DateTime   @updatedAt @map("updated_at")

  visit         Visit         @relation(fields: [visitId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  roomType      RoomType?     @relation(fields: [roomTypeId], references: [id])
  photos        Photo[]

  @@index([visitId, status])
  @@map("tasks")
}

model Photo {
  id        String      @id @default(uuid())
  taskId    String      @map("task_id")
  fileName  String      @map("file_name")
  filePath  String      @map("file_path")
  moment    PhotoMoment
  fileSize  Int?        @map("file_size")
  mimeType  String?     @map("mime_type")
  createdAt DateTime    @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, moment])
  @@index([taskId, moment])
  @@map("photos")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_log")
}
