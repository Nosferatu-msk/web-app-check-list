generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  engineer
  tm
  admin
}

enum Season {
  summer
  winter
}

enum VisitStatus {
  planned
  not_started
  in_progress
  completed
  sent
  sent_by_engineer
  sent_by_tm
  corrected_by_tm
}

enum TaskStatus {
  not_started
  in_progress
  completed
}

enum Conclusion {
  ok
  ok_with_notes
  faulty
}

enum PhotoMoment {
  before
  after
}

model User {
  id                 String   @id @default(uuid())
  fullName           String   @map("full_name")
  email              String   @unique
  passwordHash       String   @map("password_hash")
  role               UserRole @default(engineer)
  isActive           Boolean  @default(true) @map("is_active")
  mustChangePassword Boolean  @default(false) @map("must_change_password")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  visits         Visit[]              @relation("UserVisits")
  assignedVisits Visit[]              @relation("AssignedVisits")
  auditLogs      AuditLog[]
  resetTokens    PasswordResetToken[]
  tmObjects      TmObject[]           @relation("TmObjectRelation")
  tmEngineers    TmEngineer[]         @relation("TmEngineerTmRelation")
  engineersAsTm  TmEngineer[]         @relation("TmEngineerEngineerRelation")
  deletedVisits  Visit[]              @relation("DeletedBy")

  @@map("users")
}

model Address {
  id            String   @id @default(uuid())
  city          String
  street        String
  house         String
  building      String?
  fullAddress   String   @map("full_address")
  customerEmail String?  @map("customer_email")
  objectCode    String?  @unique @map("object_code")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  visits          Visit[]
  tmObjects       TmObject[]
  objectEquipment ObjectEquipment[]

  @@index([city, street])
  @@map("addresses")
}

model EquipmentType {
  id             String  @id @default(uuid())
  name           String
  code           String  @unique
  photosRequired Int     @default(1) @map("photos_required")
  isActive       Boolean @default(true) @map("is_active")

  tasks           Task[]
  recommendations Recommendation[]

  @@map("equipment_types")
}

model RoomType {
  id   String @id @default(uuid())
  name String
  code String @unique

  tasks Task[]

  @@map("room_types")
}

model Recommendation {
  id              String  @id @default(uuid())
  equipmentTypeId String  @map("equipment_type_id")
  text            String
  sortOrder       Int     @default(0) @map("sort_order")
  isActive        Boolean @default(true) @map("is_active")

  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])

  @@index([equipmentTypeId, sortOrder])
  @@map("recommendations")
}

model Visit {
  id               String      @id @default(uuid())
  userId           String      @map("user_id")
  addressId        String      @map("address_id")
  engineerName     String      @map("engineer_name")
  dateStart        DateTime    @map("date_start")
  timeStart        String      @map("time_start")
  timeEnd          String?     @map("time_end")
  season           Season
  status           VisitStatus @default(in_progress)
  assignedById     String?     @map("assigned_by_id")
  assignedAt       DateTime?   @map("assigned_at")
  sentByEngineerAt DateTime?   @map("sent_by_engineer_at")
  sentByTmAt       DateTime?   @map("sent_by_tm_at")
  tmCorrected      Boolean     @default(false) @map("tm_corrected")
  isDeleted        Boolean     @default(false) @map("is_deleted")
  deletedById      String?     @map("deleted_by_id")
  deletedAt        DateTime?   @map("deleted_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  user       User    @relation("UserVisits", fields: [userId], references: [id])
  assignedBy User?   @relation("AssignedVisits", fields: [assignedById], references: [id])
  deletedBy  User?   @relation("DeletedBy", fields: [deletedById], references: [id])
  address    Address @relation(fields: [addressId], references: [id])
  tasks      Task[]

  @@index([userId, dateStart])
  @@index([status])
  @@index([assignedById])
  @@index([isDeleted])
  @@map("visits")
}

model Task {
  id                        String      @id @default(uuid())
  visitId                   String      @map("visit_id")
  equipmentTypeId           String      @map("equipment_type_id")
  roomTypeId                String?     @map("room_type_id")
  comment                   String?
  brand                     String?
  model                     String?
  serialNumber              String?     @map("serial_number")
  sortOrder                 Int         @default(0) @map("sort_order")
  status                    TaskStatus  @default(not_started)
  parameters                Json?
  selectedRecommendationIds String[]    @default([]) @map("selected_recommendation_ids")
  additionalRecommendations String?     @map("additional_recommendations")
  conclusion                Conclusion?
  createdAt                 DateTime    @default(now()) @map("created_at")
  updatedAt                 DateTime    @updatedAt @map("updated_at")

  visit         Visit         @relation(fields: [visitId], references: [id], onDelete: Cascade)
  equipmentType EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  roomType      RoomType?     @relation(fields: [roomTypeId], references: [id])
  photos        Photo[]

  @@index([visitId, status])
  @@map("tasks")
}

model Photo {
  id        String      @id @default(uuid())
  taskId    String      @map("task_id")
  fileName  String      @map("file_name")
  filePath  String      @map("file_path")
  moment    PhotoMoment
  fileSize  Int?        @map("file_size")
  mimeType  String?     @map("mime_type")
  createdAt DateTime    @default(now()) @map("created_at")

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, moment])
  @@index([taskId, moment])
  @@map("photos")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
  @@map("audit_log")
}

model TmObject {
  id        String   @id @default(uuid())
  tmId      String   @map("tm_id")
  addressId String   @map("address_id")
  createdAt DateTime @default(now()) @map("created_at")

  tm      User    @relation("TmObjectRelation", fields: [tmId], references: [id], onDelete: Cascade)
  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@unique([tmId, addressId])
  @@index([tmId])
  @@index([addressId])
  @@map("tm_objects")
}

model TmEngineer {
  id         String   @id @default(uuid())
  tmId       String   @map("tm_id")
  engineerId String   @map("engineer_id")
  createdAt  DateTime @default(now()) @map("created_at")

  tm       User @relation("TmEngineerTmRelation", fields: [tmId], references: [id], onDelete: Cascade)
  engineer User @relation("TmEngineerEngineerRelation", fields: [engineerId], references: [id], onDelete: Cascade)

  @@unique([engineerId])
  @@index([tmId])
  @@index([engineerId])
  @@map("tm_engineers")
}

model ImportLog {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  entityType    String   @map("entity_type")
  fileName      String   @map("file_name")
  totalRows     Int      @map("total_rows")
  successRows   Int      @map("success_rows")
  duplicateRows Int      @default(0) @map("duplicate_rows")
  errorRows     Int      @map("error_rows")
  errors        Json?
  status        String   @default("completed")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([entityType])
  @@map("import_logs")
}

model ObjectEquipment {
  id                  String   @id @default(uuid())
  addressId           String   @map("address_id")
  equipmentTypeCode   String   @map("equipment_type_code")
  roomTypeCode        String   @map("room_type_code")
  brand               String?
  model               String?
  serialNumber        String?  @map("serial_number")
  locationDescription String?  @map("location_description")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  address Address @relation(fields: [addressId], references: [id], onDelete: Cascade)

  @@index([addressId])
  @@index([equipmentTypeCode])
  @@map("object_equipment")
}
