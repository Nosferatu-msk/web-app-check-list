# ─── Production Environment ───
# Скопируйте в .env и заполните своими значениями

# Database
DB_NAME=checklist
DB_USER=checklist
DB_PASS=придумайте_надёжный_пароль

# JWT (обязательно замените на случайную строку!)
JWT_SECRET=вставьте_случайную_строку_минимум_32_символа

# SMTP (email для сброса пароля)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Чек-лист инженера <noreply@your-domain.com>"

# App
CLIENT_URL=https://your-domain.com
