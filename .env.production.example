# ─── Production Environment ───
# Скопируйте в .env и заполните своими значениями

# Database
DB_NAME=checklist
DB_USER=checklist
DB_PASS=придумайте_надёжный_пароль

# JWT (обязательно замените на случайную строку!)
JWT_SECRET=вставьте_случайную_строку_минимум_32_символа

# SMTP (email для сброса пароля) — Beget
SMTP_HOST=smtp.beget.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@checkonout.ru
SMTP_PASS=пароль_от_почтового_ящика
SMTP_FROM="Чек-лист инженера <support@checkonout.ru>"

# App
CLIENT_URL=https://your-domain.com
